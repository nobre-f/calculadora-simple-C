#include <stdio.h>
#include <stdlib.h>

/* run this program using the console pauser or add your own getch, system("pause") or input loop */

int main(int argc, char *argv[]) {
	
	float num1;
	float num2;
	int opcao;
	int calcular;

	calcular = 1;

	while(calcular==1)
{
	
	printf("===CALCULADORA===\n");
	printf("1)Adicao\n");
	printf("2)Subtracao\n");
	printf("3)Multiplicacao\n");
	printf("4)Divisao\n\n");
	printf("Digite a opcao: ");
	scanf("%d", &opcao);
	
	if(opcao<1 || opcao > 4 )
	{
		printf("ERRO!");
		printf("Digite um valor de 1 a 4");
	}
	
	printf ("Digite o primeiro valor: ");
	scanf("%f", &num1);
	
	printf("Digite o segundo valor: ");
	scanf("%f", &num2);
	
	if(opcao==1)
	{
		float soma;
		soma = num1 + num2;
		printf("%f\n\n", soma);
	}
	
	else if(opcao==2)
	{
		float subtracao;
		subtracao = num1 - num2;
		printf("\n%f\n\n", subtracao);
		
	}
	
	else if(opcao==3)
	{
		float multi;
		multi = num1 * num2;
		printf("\n%f\n\n", multi);
	}
	else if(opcao==4)
	{
		if(num2==0)
		{
			printf("ERRO!\n");
			printf("DIVISAO POR ZERO!\n");
		}
		float divisao;
		divisao = num1 / num2;
		printf("\n%f\n\n", divisao);
	}
	
	
}
	

	return 0;
}
